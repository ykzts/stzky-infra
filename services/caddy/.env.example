# Caddy 環境変数テンプレート
# cp .env.example .env のうえ、必須項目を実際の値に置き換えてください。

# 必須: Cloudflare API トークン（DNS-01 チャレンジ用）
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# 必須: MCP Gateway へのアクセストークン
MCP_ACCESS_TOKEN=your-mcp-access-token

# 必須: Prometheus Basic 認証用の bcrypt ハッシュパスワード
PROMETHEUS_HASHED_PASSWORD=$2a$14$your-bcrypt-hashed-password

# 必須: Prometheus Basic 認証ユーザー名
ALLOY_PROMETHEUS_USERNAME=your-prometheus-username