# Open WebUI 環境変数テンプレート
# cp .env.example .env のうえ、必須項目を実際の値に置き換えてください。

# 必須: Hugging Face トークン（モデルダウンロード用）
HF_TOKEN=your-huggingface-token

# 必須: PostgreSQL パスワード
DB_PASSWORD=your-db-password

# 任意 (デフォルト: False): サインアップを有効にするか
ENABLE_SIGNUP=False

# 任意 (デフォルト: なし): WebUI セッション用シークレットキー
WEBUI_SECRET_KEY=your-webui-secret-key