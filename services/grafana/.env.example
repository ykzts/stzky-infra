# Grafana 環境変数テンプレート
# cp .env.example .env のうえ、必須項目を実際の値に置き換えてください。

# 必須: PostgreSQL ホスト（ホスト:ポート形式）
GF_DATABASE_HOST=database:5432

# 必須: PostgreSQL データベース名
GF_DATABASE_NAME=grafana

# 必須: PostgreSQL パスワード
GF_DATABASE_PASSWORD=your-database-password

# 必須: データベース種別
GF_DATABASE_TYPE=postgres

# 必須: PostgreSQL ユーザー名
GF_DATABASE_USER=grafana

# 必須: Redis リモートキャッシュ接続文字列
GF_REMOTE_CACHE_CONNSTR=addr=redis:6379,pool_size=100,db=0

# 必須: SMTP 送信元メールアドレス
GF_SMTP_FROM_ADDRESS=noreply@example.com

# 必須: SMTP 送信元表示名
GF_SMTP_FROM_NAME=Grafana

# 必須: SMTP サーバー（ホスト:ポート形式）
GF_SMTP_HOST=smtp.example.com:587

# 必須: SMTP パスワード
GF_SMTP_PASSWORD=your-smtp-password

# 必須: Alloy が Prometheus へ書き込む際の Basic 認証パスワード
ALLOY_PROMETHEUS_PASSWORD=your-prometheus-password

# 必須: Alloy が Prometheus へ書き込む際の Basic 認証ユーザー名
ALLOY_PROMETHEUS_USERNAME=your-prometheus-username