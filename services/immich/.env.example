# Immich 環境変数テンプレート
# cp .env.example .env のうえ、必須項目を実際の値に置き換えてください。

# 必須: PostgreSQL データベース名
DB_DATABASE_NAME=immich

# 必須: PostgreSQL パスワード
DB_PASSWORD=your-database-password

# 必須: PostgreSQL ユーザー名
DB_USERNAME=immich

# 必須: PostgreSQL データディレクトリのホストパス
DB_DATA_LOCATION=/path/to/immich/db

# 必須: アップロードファイルのホストパス
UPLOAD_LOCATION=/path/to/immich/upload