# Baserow 環境変数テンプレート
# cp .env.example .env のうえ、必須項目を実際の値に置き換えてください。

# 必須: JWT トークン署名用のシークレットキー
BASEROW_JWT_SIGNING_KEY=your-jwt-signing-key

# 必須: Django SECRET_KEY
SECRET_KEY=your-secret-key

# 任意 (デフォルト: baserow): PostgreSQL データベース名
# DATABASE_NAME=baserow

# 任意 (デフォルト: baserow): PostgreSQL ユーザー名
# DATABASE_USER=baserow

# 任意 (デフォルト: baserow): PostgreSQL パスワード
# DATABASE_PASSWORD=baserow

# 任意: S3 互換ストレージ（未設定時はローカルストレージ）
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_CUSTOM_DOMAIN=
# AWS_S3_ENDPOINT_URL=
# AWS_S3_REGION_NAME=
# AWS_STORAGE_BUCKET_NAME=

# 任意: SMTP メール送信設定
# EMAIL_SMTP=
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PASSWORD=
# EMAIL_SMTP_PORT=
# EMAIL_SMTP_USE_TLS=
# EMAIL_SMTP_USER=