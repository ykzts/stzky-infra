{
  "build": {
    "context": ".",
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "EditorConfig.EditorConfig",
        "Grafana.grafana-alloy"
      ]
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:3.0.1": {
      "moby": false,
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/github-cli:1.1.0": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/terraform:1.4.3": {
      "version": "latest"
    }
  },
  "name": "stzky infra",
  "postCreateCommand": "./scripts/bootstrap.sh",
}
